{
  "lazyCodeLoading": "requiredComponents",
  "pages": [
    "pages/index/index",
    "pages/detail/detail",
    "pages/registered-only/registered-only"
  ],
  "subpackages": [
    {
      "root": "subA",
      "pages": [
        "pages/a1/a1"
      ]
    },
    {
      "root": "subB",
      "pages": [
        "pages/b1/b1"
      ]
    },
    {
      "root": "subInd",
      "pages": [
        "pages/i1/i1"
      ],
      "independent": true
    }
  ],
  "resolveAlias": {
    "@/*": "/*",
    "~utils": "/utils/util"
  }
}
