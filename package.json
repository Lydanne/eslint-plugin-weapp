    "globals": "^17.5.0",
    "requireindex": "^1.2.0"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "eslint-doc-generator": "^3.3.2",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": "^14.17.0 || ^16.0.0 || >= 18.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
