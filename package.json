{
  "name": "eslint-plugin-weapp2",
  "version": "0.0.3",
  "description": "a weapp eslint",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "WumaCoder",
  "main": "./lib/index.js",
  "exports": "./lib/index.js",
  "scripts": {
    "lint": "npm-run-all \"lint:*\"",
