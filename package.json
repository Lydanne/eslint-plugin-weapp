{
  "name": "eslint-plugin-weapp2",
  "version": "1.2.0",
  "description": "a weapp eslint",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "author": "Lydanne",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js"
  },
  "scripts": {
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm-run-all \"update:eslint-docs -- --check\"",
    "lint:js": "eslint .",
    "test": "mocha tests/lib --recursive",
    "update:eslint-docs": "eslint-doc-generator --config-emoji recommended,✅ --config-emoji flat/recommended,🧊 --config-emoji flat/weapp,🌐"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "globals": "^17.5.0",
    "requireindex": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/json": "^1.2.0",
    "eslint": "^10.2.1",
    "eslint-doc-generator": "^3.3.2",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": "^20.19.0 || >= 22.12.0"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "@eslint/json": "^1.0.0",
    "@eslint/css": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@eslint/json": { "optional": true },
    "@eslint/css": { "optional": true }
  },
  "license": "ISC"
}
